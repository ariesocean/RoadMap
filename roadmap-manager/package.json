{
  "name": "roadmap-manager",
  "version": "1.0.0",
  "description": "macOS native desktop app for managing roadmap.md with Microsoft To Do-style UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "serve": "node dist-server/index.cjs",
    "start": "npm run build && npm run build:server && npm run serve",
    "preview": "vite preview",
    "opencode:server": "cd .. && (OPENCODE_SERVER_PASSWORD=\"\" opencode serve --port 51432 &)"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opencode-ai/sdk": "^1.2.6",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
